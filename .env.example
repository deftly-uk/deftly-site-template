# Deftly site template — environment template (safe to commit; contains NO secrets)
# Copy to .env and fill in. .env itself is git-ignored.

# === Database: Neon Postgres ===
# Pooled connection string for the serverless app runtime.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URI=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooled) connection — fallback for migrations if the pooler misbehaves.
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# === Control plane: the shared build queue (the CRM's Supabase "deftly" DB) ===
# The build_jobs queue is the ONE list the CRM writes and this engine reads. It lives in
# the CRM's database (NOT this engine's Neon DB above), and is owned by the CRM migration
# deftly-app/supabase/migrations/0006_build_queue.sql. The build worker connects here to
# claim jobs and write status + site_url back. QUEUE ONLY — tenant content stays in
# POSTGRES_URL.
#
# Least privilege: do NOT use the Supabase `postgres` superuser here. The CRM enables RLS
# on build_jobs, so provision a dedicated login that can reach the queue and ONLY the
# queue — ideally GRANT select/insert/update on build_jobs to a `deftly_engine` role plus a
# row-level-security policy admitting it (so a leaked engine credential can't read leads).
# Until that role exists, an owner/BYPASSRLS role works but is broad — treat as interim.
#
# SSL: prefer the Supabase POOLER host (publicly-trusted cert). `?sslmode=require` is
# honoured libpq-style by the worker (encrypt without strict CA verification), so the
# direct host works too; use `?sslmode=verify-full` if you want strict verification.
CONTROL_PLANE_DATABASE_URL=postgresql://deftly_engine:PASSWORD@HOST-pooler.REGION.pooler.supabase.com:5432/postgres?sslmode=require

# === Payload CMS ===
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-64-hex-chars

# === Public site URL (SEO canonical / Open Graph / admin) ===
NEXT_PUBLIC_SERVER_URL=https://your-site.vercel.app

# === Multi-tenant routing ===
# The apex that tenant subdomains hang off. A request to <sub>.<ROOT_DOMAIN> resolves
# to the tenant whose subdomain is <sub>. Use "localhost" in dev (e.g. acme.localhost).
ROOT_DOMAIN=localhost
# Base domain used to build a built site's preview URL in SUBDOMAIN mode.
# Requires REAL wildcard DNS (*.yourdomain) pointed at the engine — without it the
# engine emails a link that won't resolve. PATH mode (PREVIEW_PATH_BASE below) is
# the safe default: it works immediately with no extra DNS.
PREVIEW_BASE_DOMAIN=
# PATH mode (recommended until a wildcard *.domain is pointed at the engine): when set,
# built sites are linked as <PREVIEW_PATH_BASE>/<subdomain> and served on this same domain
# via the /s/:sub rewrite middleware — no per-subdomain DNS needed.
# e.g. PREVIEW_PATH_BASE=https://deftly-site-template.vercel.app/s
PREVIEW_PATH_BASE=
# Must be "true" for PATH-mode previews: lets the /s/:sub middleware set the trusted tenant
# override header (client-supplied overrides are always stripped, so this is safe here).
ALLOW_TENANT_HEADER_OVERRIDE=false

# === Self-serve build worker (Stage 4) ===
# Shared secret protecting POST /internal/run-worker (the CRM's on-enqueue nudge + the
# external backstop scheduler send it as `Authorization: Bearer <secret>`). Generate with
# openssl rand -hex 32. The CRM must hold the SAME value as ENGINE_WORKER_SECRET.
WORKER_TRIGGER_SECRET=
# Max jobs drained per /internal/run-worker invocation (keeps a run inside maxDuration).
WORKER_MAX_PER_RUN=5

# === Schema management ===
# Leave blank/false in every real environment: schema changes go through committed
# migrations (payload migrate), never push. Set to "true" ONLY for throwaway test DBs.
PAYLOAD_DB_PUSH=false

# === Vercel Blob (media storage; store must be PUBLIC) ===
# When set, media is stored in Blob under a per-tenant prefix (tenants/<subdomain>/...).
# When BLANK, uploads fall back to local disk (dev/tests) — no Blob needed.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# === Email: Resend (contact-form notifications + "site is ready" delivery) ===
# Free key at https://resend.com. Until set, enquiries still SAVE to the CMS and builds
# still complete; the email send is skipped (never fails the build).
RESEND_API_KEY=
# Sender identity (use onboarding@resend.dev until a domain is verified in Resend).
CONTACT_FROM_EMAIL=Enquiries <onboarding@resend.dev>
# Optional override of the From used for "your website is ready" emails (defaults to
# CONTACT_FROM_EMAIL, then onboarding@resend.dev).
SITE_READY_FROM=
# Fallback recipient if SiteSettings.notificationEmail is empty in the CMS.
CONTACT_TO_EMAIL_FALLBACK=owner@example.com

# --- "Your website is ready" conversion email (copy tuning; all optional) ---
# Sign-off name on the email (defaults to "The Deftly team").
SITE_READY_REP_NAME=
# Price shown on the claim button, e.g. "£295". Omitted from the button if blank.
SITE_READY_PRICE=
# Call-back number for the email's contact line. Falls back to "just reply to this email".
SITE_READY_CONTACT_PHONE=
# Stripe checkout link. This is the on/off flag: when SET, the email shows a REAL "Claim my
# website" button; when BLANK, it shows a greyed-out teaser ("Secure checkout: available
# shortly"). Flip this on the day payments go live — no copy change needed.
SITE_READY_CHECKOUT_URL=
# Set to "off" to hide the payment block from the email entirely.
SITE_READY_PAYMENT=

# === Seed admin (idempotent) — the platform operator (super admin) on first seed ===
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong
# Password set on each seeded demo tenant's owner login (ashworth/pennine).
SEED_TENANT_PASSWORD=change-me-strong
