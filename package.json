{
  "name": "deftly-site-template",
  "version": "2.0.0",
  "description": "Deftly site template — CMS-first Next.js + Payload site for UK trade businesses",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "build": "next build",
    "build:prod": "payload migrate && payload generate:importmap && next build",
    "start": "next start",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "seed": "node --env-file-if-exists=.env --import tsx src/seed/index.ts",
    "build:worker": "node --env-file-if-exists=.env --import tsx src/scripts/run-build-worker.ts",
    "test": "node scripts/with-test-db.mjs",
    "test:vitest": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-multi-tenant": "^3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-vercel-blob": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "graphql": "^16.11.0",
    "next": "16.2.9",
    "payload": "3.85.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.14.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
