{
  "name": "deftly-site-template",
  "version": "1.0.0",
  "description": "Deftly site template — Next.js + Payload CMS for client websites",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "seed": "tsx src/seed/index.ts",
    "seed:prod": "tsx src/seed/index.ts --environment production",
    "curate": "node scripts/curate-images.mjs",
    "go-live": "node scripts/go-live.mjs"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "^3.80.0",
    "@payloadcms/next": "^3.80.0",
    "@payloadcms/richtext-lexical": "^3.80.0",
    "@payloadcms/storage-vercel-blob": "^3.80.0",
    "@payloadcms/ui": "^3.80.0",
    "graphql": "^16.13.1",
    "next": "^16.2.1",
    "payload": "^3.80.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
